# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/clipbandit
DATABASE_SYNC_URL=postgresql://postgres:postgres@postgres:5432/clipbandit
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=clipbandit

# Redis + Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Auth
NEXTAUTH_SECRET=changeme-generate-a-real-secret-in-production
NEXTAUTH_URL=http://localhost:3001
ADMIN_EMAIL=admin@clipbandit.com
ADMIN_PASSWORD=changeme123

# JWT (used by backend)
JWT_SECRET_KEY=changeme-jwt-secret-key-32-chars-min

# Cloudflare R2 (fill in when ready)
R2_ACCOUNT_ID=placeholder
R2_ACCESS_KEY_ID=placeholder
R2_SECRET_ACCESS_KEY=placeholder
R2_BUCKET_NAME=clipbandit
R2_ENDPOINT_URL=https://placeholder.r2.cloudflarestorage.com
R2_PUBLIC_URL=placeholder

# Anthropic (legacy, currently unused)
ANTHROPIC_API_KEY=placeholder

# DeepSeek (for clip-level title/hashtag generation)
DEEPSEEK_API_KEY=placeholder
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SEC=30

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=5000
MAX_CONCURRENT_JOBS=2
